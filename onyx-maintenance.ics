BEGIN:VALARM
TRIGGER:-P1D
ACTION:DISPLAY
END:VALARM
END:VEVENT

BEGIN:VEVENT
UID:onyx-quarterly-pricing@onyxstudios.ai
DTSTAMP:20260520T060000Z
DTSTART:20260701T140000
DTEND:20260701T150000
SUMMARY:💵 定價 / 客戶詢問統計（每季）
DESCRIPTION:看當季數據：\n- 哪些語系詢問最多？\n- 哪個檔位（AI 即時 / 聲音導演 / 真人）成交率最高？\n- 平均報價金額\n- 流失點：客戶在哪個步驟跑掉\n\n根據數據調整定價策略 / 文案。
RRULE:FREQ=MONTHLY;INTERVAL=3;BYMONTHDAY=1
BEGIN:VALARM
TRIGGER:-P1D
ACTION:DISPLAY
END:VALARM
END:VEVENT

