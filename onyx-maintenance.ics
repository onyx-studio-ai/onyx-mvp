BEGIN:VEVENT
UID:onyx-weekly-supabase-backup@onyxstudios.ai
DTSTAMP:20260520T060000Z
DTSTART:20260524T100000
DTEND:20260524T101500
SUMMARY:💾 Supabase 資料備份（每週）
DESCRIPTION:手動跑 db dump 並存到 SSD（升 Pro 之前必做）：\n\ncd "/Volumes/WingAI SSD/Claude/Projects/工程部/onyx-platform/onyx-platform/project"\nmkdir -p backups\nsupabase db dump --data-only > backups/$(date +%Y%m%d)-data.sql\nsupabase db dump --schema-only > backups/$(date +%Y%m%d)-schema.sql\n\n升 Pro 後可以每月一次或更少。
RRULE:FREQ=WEEKLY;BYDAY=SU
BEGIN:VALARM
TRIGGER:-PT15M
ACTION:DISPLAY
DESCRIPTION:Onyx — 跑 Supabase 備份
END:VALARM
END:VEVENT

