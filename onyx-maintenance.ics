UID:onyx-quarterly-legal@onyxstudios.ai
DTSTAMP:20260520T060000Z
DTSTART:20260701T160000
DTEND:20260701T163000
SUMMARY:⚖️ 法律文件審查（每季）
DESCRIPTION:看 /legal/terms /legal/privacy /legal/aup /legal/refund：\n- 跟現在實際服務內容對得上嗎？\n- 定價有沒有跟 ToS §3 對得上？\n- Paddle 實體有沒有改？\n- 個資處理範圍有沒有變？
RRULE:FREQ=MONTHLY;INTERVAL=3;BYMONTHDAY=1
BEGIN:VALARM
TRIGGER:-P1D
ACTION:DISPLAY
END:VALARM
END:VEVENT

